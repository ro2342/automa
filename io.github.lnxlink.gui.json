{
  "app-id": "io.github.lnxlink.gui",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "command": "lnxlink-gui",

  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",

    "--filesystem=~/.config/lnxlink:rw",

    "--talk-name=org.freedesktop.Flatpak",

    "--talk-name=org.freedesktop.systemd1",

    "--talk-name=org.kde.StatusNotifierWatcher",
    "--talk-name=com.canonical.AppMenu.Registrar",
    "--talk-name=com.canonical.indicator.application",
    "--talk-name=org.ayatana.indicator.application",

    "--talk-name=org.freedesktop.Notifications",

    "--talk-name=org.freedesktop.DBus"
  ],

  "build-options": {
    "no-debuginfo": false
  },

  "modules": [
    {
      "name": "python3-ruamel-yaml",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-index --find-links=. --prefix=/app ruamel.yaml ruamel.yaml.clib"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/source/r/ruamel.yaml/ruamel.yaml-0.18.6.tar.gz",
          "sha256": "8b27e6a217e786c6fbe5634d8f3f11bc63e0f80f6a5890f28863d9c45aac311b",
          "dest-filename": "ruamel.yaml-0.18.6.tar.gz"
        },
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/source/r/ruamel.yaml.clib/ruamel.yaml.clib-0.2.8.tar.gz",
          "sha256": "beb2e0404003de9a4cab9753a8805a8fe9320ee6673136ed7f04255fe60bb512",
          "dest-filename": "ruamel.yaml.clib-0.2.8.tar.gz"
        }
      ]
    },

    {
      "name": "libayatana-appindicator",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DENABLE_BINDINGS_MONO=NO",
        "-DENABLE_BINDINGS_VALA=NO"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/AyatanaIndicators/libayatana-appindicator/archive/0.5.93.tar.gz",
          "sha256": "placeholder-replace-with-real-sha256"
        }
      ]
    },

    {
      "name": "lnxlink-gui",
      "buildsystem": "simple",
      "build-commands": [
        "install -D main.py           /app/lib/lnxlink-gui/main.py",
        "install -D config_manager.py /app/lib/lnxlink-gui/config_manager.py",
        "install -D service_manager.py /app/lib/lnxlink-gui/service_manager.py",
        "install -Dm644 pages/__init__.py  /app/lib/lnxlink-gui/pages/__init__.py",
        "install -D pages/dashboard.py    /app/lib/lnxlink-gui/pages/dashboard.py",
        "install -D pages/mqtt_config.py  /app/lib/lnxlink-gui/pages/mqtt_config.py",
        "install -D pages/sensors.py      /app/lib/lnxlink-gui/pages/sensors.py",
        "install -D pages/commands.py     /app/lib/lnxlink-gui/pages/commands.py",

        "install -Dm755 data/lnxlink-gui.sh /app/bin/lnxlink-gui",

        "install -Dm644 data/io.github.lnxlink.gui.desktop /app/share/applications/io.github.lnxlink.gui.desktop",
        "install -Dm644 data/io.github.lnxlink.gui.metainfo.xml /app/share/metainfo/io.github.lnxlink.gui.metainfo.xml",

        "install -Dm644 data/icons/hicolor/scalable/apps/io.github.lnxlink.gui.svg /app/share/icons/hicolor/scalable/apps/io.github.lnxlink.gui.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
